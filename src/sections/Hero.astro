---
import Link from '@/components/Link.astro'
import { HeroBackground } from '@/components/ui/HeroBackground'
import { Image } from 'astro:assets'
import doodle from '@/assets/HeroDoodle.svg'
import Icon from '@/components/Icon.astro'
---

<section
	class="mx-auto flex min-h-screen flex-1 flex-col-reverse items-center justify-center px-4 md:px-0 xl:flex-row"
>
	<div class="z-10 flex w-full flex-col justify-center gap-3 xl:h-full">
		<div class="flex flex-col gap-2">
			<h1 class="text-4xl text-muted-foreground">
				Hi there! I'm <strong
					class="bg-gradient-to-tr from-green-400 to-green-800 bg-clip-text font-bold text-transparent underline-offset-2"
					>Noé Tatoud</strong
				>
			</h1>
			<span class="text-xl">
				{'>'}
				Web developer &amp; Climber<span class="animate-pulse duration-1000">_</span>
			</span>
		</div>
		<ul class="flex w-full list-disc flex-col gap-2 p-4 text-muted-foreground">
			<li>
				Currently working at <Link href="https://www.bearstudio.fr/" title="Bearstudio"
					>Bearstudio</Link
				>
				&#128059;
			</li>
			<li>
				I live in
				<Link href="https://www.google.fr/maps/place/Rouen" title="Rouen on google maps">Rouen</Link
				>, FRANCE &#127467;&#127479;
			</li>
		</ul>
		<div class="flex gap-4 text-xl">
			<Link href="https://twitter.com/nowaytatoud" title="@nowaytatoud">
				<Icon icon="twitter-logo" size="5" />
			</Link>
			<Link href="https://github.com/ntatoud" title="@ntatoud">
				<Icon icon="github-logo" size="5" />
			</Link>
			<Link href="https://linkedin.com/in/noetatoud" title="@noetatoud">
				<Icon icon="linkedin-logo" size="5" />
			</Link>
		</div>
	</div>
	<div class="relative xl:-ml-36 xl:scale-125">
		<div
			class="absolute -z-10 hidden h-full w-full rounded-full bg-background blur-xl xl:flex xl:scale-110"
		>
		</div>

		<div class="absolute right-5 top-5 -z-10 h-1/3 w-1/3 rounded-full bg-green-800"></div>
		<Image
			class="aspect-square object-cover object-left-top lg:aspect-auto lg:w-full xl:h-full"
			src={doodle}
			alt="Doodle"
			loading="eager"
		/>
	</div>
	<div class="absolute -right-10 -z-20 hidden overflow-hidden rounded-full opacity-20 xl:flex">
		<HeroBackground />
	</div>
</section>
